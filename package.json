{
  "name": "keephero",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -F !browser -F !portal build",
    "deps": "ncu -ws -u",
    "coverage": "sensible-browser coverage/index.html",
    "generate": "pnpm --parallel generate",
    "format": "vp fmt",
    "leaks": "gitleaks git --config=.gitleaks.toml --verbose --redact",
    "lint": "vp fmt --check && vp lint",
    "install:ci": "pnpm install --ignore-scripts",
    "prepare": "lefthook install",
    "unit": "vp test",
    "scan": "pnpm leaks && pnpm vulns",
    "start": "pnpm --parallel -F engine -F website start",
    "test": "pnpm lint && pnpm type && pnpm unit",
    "type": "pnpm -r type",
    "vulns": "semgrep --config=p/typescript --config=p/nodejs --config=p/owasp-top-ten --config=p/secrets --exclude=\"**/fixtures/**\" --metrics=off"
  },
  "devDependencies": {
    "@semantic-release/exec": "7.1.0",
    "@types/node": "24.2.0",
    "@vitest/coverage-v8": "4.0.8",
    "@vitest/ui": "4.0.8",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "execa": "9.6.0",
    "lefthook": "^2.1.5",
    "npm-check-updates": "18.0.1",
    "semantic-release": "24.2.9",
    "tempy": "3.1.0",
    "type-fest": "4.41.0",
    "typescript": "5.9.2",
    "vite": "7.3.2",
    "vite-plus": "0.1.19",
    "vitest": "4.0.8"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^11.0.0"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
